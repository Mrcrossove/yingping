# 环境变量配置（复制为 .env 并修改）
DATABASE_URL="mysql://root:password@localhost:3306/beverage_order"
JWT_SECRET="your-jwt-secret-change-me"
JWT_EXPIRES_IN="7d"
UPLOAD_DIR="./uploads"
PORT=3000
CORS_ORIGINS="https://your-admin-domain.com,https://your-miniapp-domain.com"
ENABLE_SWAGGER="false"

# 腾讯云 COS + CDN 图片上传配置
# 留空则自动使用服务器本地 uploads 目录兜底
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_BUCKET="beverage-order-1250000000"
COS_REGION="ap-guangzhou"
COS_KEY_PREFIX="beverage-order"
COS_CDN_DOMAIN="https://cdn.example.com"

# 腾讯位置服务配置（用于小程序地图选点后的逆地址解析）
TENCENT_MAP_KEY="your_tencent_map_key"

# 微信小程序配置（上线前替换为真实值）
WX_APPID="wxe08a23a03ce5f1ba"
WX_SECRET="your_app_secret_here"
WX_MCH_ID="your_wechat_pay_mch_id"
WX_SERIAL_NO="your_wechat_pay_cert_serial_no"
WX_PRIVATE_KEY_PATH="/opt/beverage-order/server/certs/apiclient_key.pem"
WX_PLATFORM_CERT_PATH="/opt/beverage-order/server/certs/wechatpay_platform.pem"
WX_API_V3_KEY="your_32_byte_wechat_pay_api_v3_key"
WX_PAY_NOTIFY_URL="https://api.gzzzyp.com/api/payments/notify"
WX_REFUND_NOTIFY_URL="https://api.gzzzyp.com/api/payments/refund-notify"
