generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255)
  realName  String   @map("real_name") @db.VarChar(50)
  role      Role     @default(merchant)
  phone     String?  @db.VarChar(20)
  openid    String?  @unique @db.VarChar(64)
  avatar    String?  @db.VarChar(500)
  status    Int      @default(1) @db.TinyInt
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  merchantOrders      Order[]            @relation("MerchantOrders")
  salespersonOrders   Order[]            @relation("SalespersonOrders")
  makerOrders         Order[]            @relation("MakerOrders")
  deliveryOrders      Order[]            @relation("DeliveryOrders")
  adminPermissions     AdminPermission[]
  orderFlows          OrderFlow[]
  earnings            Earning[]
  withdrawals         Withdrawal[]
  withdrawalItems     WithdrawalItem[]
  promotionCodes      PromotionCode[]
  merchantBindings    MerchantBinding[]  @relation("MbMerchant")
  promoterBindings    MerchantBinding[]  @relation("MbPromoter")
  merchantProfile      MerchantProfile?
  promoterMerchantLeads PromoterMerchantLead[]
  notifications      Notification[]
  addresses           Address[]
  reviews             Review[]

  @@map("users")
}

enum Role {
  boss
  admin
  salesperson
  maker
  delivery
  promoter
  merchant
  other
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50)
  code        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions  RolePermission[]
  adminPermissions AdminPermission[]

  @@map("permissions")
}

model RolePermission {
  id           Int      @id @default(autoincrement())
  role         Role
  permissionId Int      @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([role, permissionId])
  @@map("role_permissions")
}

model AdminPermission {
  id           Int      @id @default(autoincrement())
  adminId      Int      @map("admin_id")
  permissionId Int      @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  admin      User       @relation(fields: [adminId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([adminId, permissionId])
  @@map("admin_permissions")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  sort      Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  products        Product[]

  @@map("categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  categoryId  Int      @map("category_id")
  price       Decimal  @db.Decimal(10, 2)
  image       String?  @db.VarChar(500)
  unit        String?  @default("杯") @db.VarChar(10)
  description String?  @db.Text
  detailDescription String? @map("detail_description") @db.Text
  detailImages Json?    @map("detail_images")
  specText    String?   @map("spec_text") @db.Text
  storageText String?   @map("storage_text") @db.Text
  status      Int      @default(1) @db.TinyInt
  stock       Int?     @default(0)
  minStock    Int?     @default(10) @map("min_stock")
  makerRate   Decimal? @db.Decimal(10, 2) @map("maker_rate")
  deliveryRate Decimal? @db.Decimal(10, 2) @map("delivery_rate")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  commissionRules CommissionRule[]

  @@map("products")
}

model Order {
  id             Int         @id @default(autoincrement())
  orderNo        String      @unique @map("order_no") @db.VarChar(32)
  merchantId     Int         @map("merchant_id")
  salespersonId  Int?        @map("salesperson_id")
  makerId        Int?        @map("maker_id")
  deliveryId     Int?        @map("delivery_id")
  totalAmount    Decimal     @map("total_amount") @db.Decimal(10, 2)
  status         OrderStatus @default(pending)
  note           String?     @db.Text
  addressId      Int?        @map("address_id")
  receiverName   String?     @map("receiver_name") @db.VarChar(30)
  receiverPhone  String?     @map("receiver_phone") @db.VarChar(20)
  receiverAddress String?    @map("receiver_address") @db.VarChar(500)
  receiverLocationName String? @map("receiver_location_name") @db.VarChar(100)
  receiverLatitude Decimal?   @map("receiver_latitude") @db.Decimal(10, 6)
  receiverLongitude Decimal?  @map("receiver_longitude") @db.Decimal(10, 6)
  receiverAdcode String?      @map("receiver_adcode") @db.VarChar(12)
  stockDeducted Boolean       @default(false) @map("stock_deducted")
  settlementType OrderSettlementType @default(wechat) @map("settlement_type")
  settlementStatus OrderSettlementStatus @default(unpaid) @map("settlement_status")
  settledAt      DateTime?   @map("settled_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  merchant    User        @relation("MerchantOrders", fields: [merchantId], references: [id])
  salesperson User?       @relation("SalespersonOrders", fields: [salespersonId], references: [id])
  maker       User?       @relation("MakerOrders", fields: [makerId], references: [id])
  delivery    User?       @relation("DeliveryOrders", fields: [deliveryId], references: [id])
  items       OrderItem[]
  flows       OrderFlow[]
  earnings    Earning[]
  payment     Payment?
  reviews     Review[]

  @@map("orders")
}

enum OrderStatus {
  pending
  accepted
  making
  made
  delivering
  delivered
  completed
  cancelled
}

enum OrderSettlementType {
  wechat
  monthly
}

enum OrderSettlementStatus {
  unpaid
  paid
  monthly_pending
  monthly_settled
  refunding
  refunded
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderFlow {
  id         Int      @id @default(autoincrement())
  orderId    Int      @map("order_id")
  fromRole   Role     @map("from_role")
  toRole     Role     @map("to_role")
  operatorId Int      @map("operator_id")
  action     String   @db.VarChar(50)
  remark     String?  @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  order    Order @relation(fields: [orderId], references: [id])
  operator User  @relation(fields: [operatorId], references: [id])

  @@map("order_flows")
}

model CommissionRule {
  id         Int      @id @default(autoincrement())
  productId  Int      @map("product_id")
  role       Role
  type       CommissionType @default(percentage)
  value      Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, role])
  @@map("commission_rules")
}

enum CommissionType {
  percentage
  fixed
}

model Earning {
  id        Int           @id @default(autoincrement())
  userId    Int           @map("user_id")
  orderId   Int           @map("order_id")
  orderNo   String        @map("order_no") @db.VarChar(32)
  amount    Decimal       @db.Decimal(10, 2)
  role      Role
  type      EarningType   @default(commission)
  status    EarningStatus @default(pending_settle)
  createdAt DateTime      @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  order Order @relation(fields: [orderId], references: [id])
  withdrawalItems WithdrawalItem[]

  @@map("earnings")
}

enum EarningType {
  commission
  reward
}

enum EarningStatus {
  pending_settle
  settled
  withdrawn
}

model Withdrawal {
  id          Int              @id @default(autoincrement())
  userId      Int              @map("user_id")
  amount      Decimal          @db.Decimal(10, 2)
  accountType String           @map("account_type") @db.VarChar(20)
  accountInfo String           @map("account_info") @db.VarChar(200)
  status      WithdrawalStatus @default(pending)
  remark      String?          @db.VarChar(500)
  createdAt   DateTime         @default(now()) @map("created_at")
  processedAt DateTime?        @map("processed_at")

  user User @relation(fields: [userId], references: [id])
  items WithdrawalItem[]

  @@map("withdrawals")
}

model WithdrawalItem {
  id           Int      @id @default(autoincrement())
  withdrawalId Int     @map("withdrawal_id")
  earningId    Int     @map("earning_id")
  userId        Int     @map("user_id")
  amount        Decimal @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  withdrawal Withdrawal @relation(fields: [withdrawalId], references: [id])
  earning    Earning    @relation(fields: [earningId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([earningId])
  @@map("withdrawal_items")
}

enum WithdrawalStatus {
  pending
  approved
  rejected
  paid
}

model PromotionCode {
  id         Int      @id @default(autoincrement())
  code       String   @unique @db.VarChar(20)
  promoterId Int      @map("promoter_id")
  status     Int      @default(1) @db.TinyInt
  createdAt  DateTime @default(now()) @map("created_at")

  promoter User @relation(fields: [promoterId], references: [id])

  @@map("promotion_codes")
}

model MerchantBinding {
  id         Int      @id @default(autoincrement())
  merchantId Int      @unique @map("merchant_id")
  promoterId Int      @map("promoter_id")
  createdAt  DateTime @default(now()) @map("created_at")

  merchant User @relation("MbMerchant", fields: [merchantId], references: [id])
  promoter User @relation("MbPromoter", fields: [promoterId], references: [id])

  @@map("merchant_bindings")
}

model MerchantProfile {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique @map("user_id")
  shopName     String?  @map("shop_name") @db.VarChar(100)
  shopAddress  String?  @map("shop_address") @db.VarChar(300)
  description  String?  @db.Text
  licenseImage String?  @map("license_image") @db.VarChar(500)
  contactName  String?  @map("contact_name") @db.VarChar(50)
  contactPhone String?  @map("contact_phone") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("merchant_profiles")
}

model PromoterMerchantLead {
  id           Int                @id @default(autoincrement())
  promoterId   Int                @map("promoter_id")
  merchantName String             @map("merchant_name") @db.VarChar(100)
  contactName  String?            @map("contact_name") @db.VarChar(50)
  phone        String             @db.VarChar(20)
  address      String?            @db.VarChar(300)
  remark       String?            @db.VarChar(500)
  status       MerchantLeadStatus @default(pending)
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  promoter User @relation(fields: [promoterId], references: [id])

  @@unique([promoterId, phone])
  @@map("promoter_merchant_leads")
}

enum MerchantLeadStatus {
  pending
  followed
  converted
  rejected
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String   @db.VarChar(200)
  content   String?  @db.Text
  type      String   @default("system") @db.VarChar(30)
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  username  String?  @db.VarChar(50)
  role      String?  @db.VarChar(30)
  action    String   @db.VarChar(50)
  resource  String?  @db.VarChar(100)
  resourceId Int?    @map("resource_id")
  detail    String?  @db.Text
  ip        String?  @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model Payment {
  id            Int      @id @default(autoincrement())
  orderId       Int      @unique @map("order_id")
  orderNo       String   @map("order_no") @db.VarChar(32)
  userId        Int      @map("user_id")
  amount        Decimal  @db.Decimal(10, 2)
  prepayId      String?  @unique @map("prepay_id") @db.VarChar(64)
  transactionId String?  @unique @map("transaction_id") @db.VarChar(64)
  status        PaymentStatus @default(pending)
  createdAt     DateTime @default(now()) @map("created_at")
  paidAt        DateTime? @map("paid_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

enum PaymentStatus {
  pending
  paid
  refunding
  refunded
  failed
}

model Address {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String   @db.VarChar(30)
  phone     String   @db.VarChar(20)
  province  String?  @db.VarChar(20)
  city      String?  @db.VarChar(20)
  district  String?  @db.VarChar(20)
  detail    String   @db.VarChar(200)
  locationName String? @map("location_name") @db.VarChar(100)
  latitude  Decimal? @db.Decimal(10, 6)
  longitude Decimal? @db.Decimal(10, 6)
  adcode    String?  @db.VarChar(12)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("addresses")
}

model Review {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  userId    Int      @map("user_id")
  rating    Int      @default(5) @db.TinyInt
  content   String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([orderId, userId])
  @@map("reviews")
}

model Banner {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(100)
  image     String   @db.VarChar(500)
  link      String?  @db.VarChar(500)
  sort      Int      @default(0)
  status    Int      @default(1) @db.TinyInt
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("banners")
}

model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(80)
  value       String?  @db.VarChar(500)
  description String?  @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
